{
  "name": "@universal-middleware/node",
  "version": "0.0.0",
  "type": "module",
  "description": "Node.js utilities for universal middlewares",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./request": "./dist/request.js",
    "./response": "./dist/response.js"
  },
  "author": "Joël Charles <joel.charles91@gmail.com>",
  "repository": "https://github.com/magne4000/universal-middleware",
  "license": "MIT",
  "scripts": {
    "build": "rimraf dist && tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm build",
    "test:typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@universal-middleware/core": "workspace:^"
  },
  "devDependencies": {
    "@swc/core": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "sideEffects": false,
  "keywords": [
    "node",
    "universal-middleware",
    "middleware",
    "handlers",
    "server-adapters",
    "universal-server",
    "request-handling"
  ]
}
